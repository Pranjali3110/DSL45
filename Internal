#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

Node* head = NULL;

// Insert at beginning
void insert(int val) {
    Node* n = new Node;
    n->data = val;
    n->next = head;
    head = n;
}

// Delete at any position
void del(int pos) {
    if (head == NULL) {
        cout << "List is empty\n";
        return;
    }

    Node* temp = head;

    if (pos == 1) {
        head = temp->next;
        delete temp;
        return;
    }

    for (int i = 1; i < pos - 1; i++) {
        if (temp->next == NULL) {
            cout << "Invalid position\n";
            return;
        }
        temp = temp->next;
    }

    Node* t = temp->next;
    if (t == NULL) {
        cout << "Invalid position\n";
        return;
    }

    temp->next = t->next;
    delete t;
}

// Display list
void display() {
    Node* temp = head;
    if (temp == NULL) {
        cout << "List is empty\n";
        return;
    }

    while (temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL\n";
}

int main() {
    int choice, val, pos;

    while (true) {
        cout << "\n1.Insert\n2.Delete\n3.Display\n4.Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {
            case 1:
                cout << "Enter value: ";
                cin >> val;
                insert(val);
                break;

            case 2:
                cout << "Enter position: ";
                cin >> pos;
                del(pos);
                break;

            case 3:
                display();
                break;

            case 4:
                return 0;

            default:
                cout << "Invalid choice\n";
        }
    }
}
